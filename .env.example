# Copy this file to .env for local development and fill in real values.
# In production (Vercel), set these under Project Settings > Environment Variables instead --
# .env is gitignored and is never deployed.

# Local Postgres (used when DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=nilecrest_holdings
DB_USER=postgres
DB_PASSWORD=

# Production Postgres (Neon / Supabase / Railway, etc.) -- takes priority over DB_* above
DATABASE_URL=

# Generate a real value with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Comma-separated list of frontend origins allowed to call this API directly.
# Leave empty for local dev. Once on your real domain, set both with and
# without www, e.g.:
# CORS_ORIGINS=https://nilecrestholdings.com,https://www.nilecrestholdings.com
CORS_ORIGINS=

# Cloudinary -- used to store uploaded files (quote attachments, job application
# CVs) since Railway's local disk is wiped on every redeploy.
# Sign up free at https://cloudinary.com -- these three values are on your
# dashboard home page after signup.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Resend -- used to automatically email clients their invoice/payment link
# when staff create an invoice. Sign up free at https://resend.com
# (3,000 emails/month free tier). RESEND_FROM_EMAIL must be a verified
# sender -- use 'onboarding@resend.dev' for testing before you verify
# your own domain.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Nilecrest Holdings <onboarding@resend.dev>

# The real public URL of this site -- used to build absolute links in
# emails (relative paths like /pay.html don't work from inside an email).
# Local dev: http://localhost:3000
# Production: your Railway URL, or your custom domain once you have one.
SITE_URL=http://localhost:3000
